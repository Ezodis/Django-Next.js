{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@app/api-client":    ["./packages/api-client/src"],
      "@app/api-client/*":  ["./packages/api-client/src/*"],
      "@app/constants":     ["./packages/constants/src"],
      "@app/constants/*":   ["./packages/constants/src/*"],
      "@app/storage":       ["./packages/storage/src"],
      "@app/storage/*":     ["./packages/storage/src/*"],
      "@app/theme":         ["./packages/theme/src"],
      "@app/theme/*":       ["./packages/theme/src/*"],
      "@app/types":         ["./packages/types/src"],
      "@app/types/*":       ["./packages/types/src/*"],
      "@app/utils":         ["./packages/utils/src"],
      "@app/utils/*":       ["./packages/utils/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
