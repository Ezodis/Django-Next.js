{
  "name": "elitecar-frontend",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "web",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=web",
    "build": "npm run build:packages && npm run build --workspace=web",
    "build:packages": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspace=web"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  }
}
