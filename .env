# ══════════════════════════════════════════════════════════════════════════════
# Elite Car – Single Source of Truth
# This file is loaded by Docker Compose, the mobile run script, and EAS builds.
# It is gitignored. Never commit real secrets.
#
# Infrastructure defaults (DB connection, API URLs, email transport) are
# hardcoded in dev.yml / settings.py — only secrets and
# environment-specific values belong here.
# ══════════════════════════════════════════════════════════════════════════════

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_DEBUG=true
# Generate a strong key for production:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=INSECURE-DEV-KEY-CHANGE-IN-PRODUCTION
DOMAIN=localhost

# ── Django superuser (created on first run) ───────────────────────────────────
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com

# ── Google Cloud Storage ──────────────────────────────────────────────────────
# https://console.cloud.google.com/storage/browser
GCS_BUCKET_NAME=your_gcs_bucket_name_here
GCS_PROJECT_ID=your_gcs_project_id_here
# Paste the full service account JSON as a single line:
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# ── Stripe ────────────────────────────────────────────────────────────────────
# Keys: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# ── Google Maps / Places API ──────────────────────────────────────────────────
# Get your API key: https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API, Maps SDK for Android/iOS, Places API,
#         Directions API, Roads API, Geocoding API
GOOGLE_MAPS_API_KEY=\
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=\
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=\

# ── Expo / EAS ────────────────────────────────────────────────────────────────
# Generate at: https://expo.dev/settings/access-tokens
EXPO_TOKEN=\-\-\

# ── Email credentials (SMTP – production only) ────────────────────────────────
# Transport settings (host, port, TLS) are hardcoded in settings.py.
# Only credentials need to be set here.
# EMAIL_HOST_USER=your@email.com
# EMAIL_HOST_PASSWORD=your_app_password
# DEFAULT_FROM_EMAIL=noreply@elitecar.app

# ── ML Service (production only) ──────────────────────────────────────────────
# Leave empty for development (built-in endpoints used).
# ML_SERVICE_URL=https://ml.elitecar.app

# ── Metro bundler (mobile dev only) ──────────────────────────────────────────
# iOS Simulator: localhost | Android Emulator: 10.0.2.2 | Physical device: <LAN-IP>
# REACT_NATIVE_PACKAGER_HOSTNAME=localhost
